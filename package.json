{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp -r dist/* ../backend/src/public/",
    "lint": "eslint .",
    "sync": "npm run sync:to-backend",
    "sync:to-backend": "rsync -av --delete src/models/ ../backend/src/models && rsync -av src/utils/data.* ../backend/src/utils/",
    "sync:from-backend": "rsync -av --delete ../backend/src/models/ src/models && rsync -av ../backend/src/utils/data.* src/utils/",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/oswald": "^5.2.5",
    "@fontsource/give-you-glory": "^5.2.8",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.8.4",
    "gsap": "^3.13.0",
    "postcss-preset-env": "^10.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^24.9.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "sass": "^1.93.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "zod": "^4.1.12"
  }
}
